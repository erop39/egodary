diff --git a/egodary/web/static/css/app.css b/egodary/web/static/css/app.css
--- a/egodary/web/static/css/app.css
+++ b/egodary/web/static/css/app.css
@@ -2843,3 +2843,84 @@ select:disabled {
   font-size: 11px;
   color: var(--text-muted);
 }
+
+.forge-result-actions {
+  display: flex;
+  gap: 6px;
+  margin-top: 6px;
+}
+
+/* =========================================================
+   Forge quick settings (inline sidebar panel)
+   ========================================================= */
+
+.forge-quick-settings {
+  margin-bottom: 8px;
+}
+
+.forge-quick-summary {
+  font-size: 12px;
+  color: var(--text-muted);
+  cursor: pointer;
+  user-select: none;
+  padding: 4px 0;
+  list-style: none;
+  display: flex;
+  align-items: center;
+  gap: 4px;
+}
+
+.forge-quick-summary::-webkit-details-marker { display: none; }
+
+.forge-quick-settings[open] .forge-quick-summary {
+  color: var(--accent);
+  margin-bottom: 8px;
+}
+
+.forge-quick-grid {
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: 6px;
+  margin-bottom: 8px;
+}
+
+.forge-quick-grid label,
+.forge-quick-hires label {
+  display: flex;
+  flex-direction: column;
+  font-size: 11px;
+  color: var(--text-muted);
+  gap: 3px;
+}
+
+.forge-quick-grid label.span-2 { grid-column: span 2; }
+
+.forge-quick-grid input,
+.forge-quick-hires input[type="number"],
+.forge-quick-hires input[type="text"] {
+  background: var(--bg-secondary);
+  border: 1px solid var(--border);
+  border-radius: 4px;
+  color: var(--text);
+  font-size: 12px;
+  padding: 3px 6px;
+  width: 100%;
+}
+
+.forge-quick-hires {
+  margin-bottom: 6px;
+}
+
+.forge-quick-hires-params {
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: 6px;
+  margin-top: 6px;
+  overflow: hidden;
+  max-height: 0;
+  transition: max-height 0.2s ease;
+}
+
+.forge-quick-hires-params.visible {
+  max-height: 60px;
+}
