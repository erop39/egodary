+++ b/egodary/web/static/index.html
@@ -793,6 +793,28 @@
           <span class="forge-status-dot" id="forge-status-dot" title="Forge status"></span>
         </div>
         <p class="card-hint" id="forge-send-hint">Forge не настроен — включите в Advanced → Forge.</p>
